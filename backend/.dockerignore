# Files/directories to exclude from the Docker build context.

# Maven local repo (Maven runs inside Docker now)
.m2/

# Host build output — JAR is built inside Docker, not copied from the host
target/

# IDE & editor files
.idea/
*.iml
.vscode/

# Secrets — never in the build context
.env
*.env

# Git
.git/
.gitignore

# OS
.DS_Store
Thumbs.db

# Docs
*.md
