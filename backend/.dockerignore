# Files/directories to exclude from the Docker build context.
# Keeping the build context small speeds up `docker build`.

# Maven build output — EXCLUDED except the fat JAR we copy in.
# target/ is NOT excluded: we COPY target/*.jar into the image.
# Only exclude the Maven local repo used during development.
.m2/

# IDE & editor files
.idea/
*.iml
.vscode/

# Environment files — NEVER include secrets in the build context
.env
*.env

# Git
.git/
.gitignore

# OS
.DS_Store
Thumbs.db

# Documentation
*.md
