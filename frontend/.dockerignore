# Files/directories to exclude from the Docker build context for the frontend.

# Dependencies are not needed — only the pre-built dist/ is copied into the image
node_modules/

# Build outputs are INCLUDED (we copy dist/ into the nginx image)

# Git
.git/
.gitignore

# Editor & OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docs
*.md

# Env files
.env
.env.local
*.env
